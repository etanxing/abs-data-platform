{
  "name": "@abs/pdf-generator",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "pnpm build && node --experimental-strip-types test-generate.ts",
    "test:live": "pnpm build && node --experimental-strip-types test-live.ts",
    "test:fonts": "pnpm build && node --experimental-strip-types test-fonts.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@abs/data": "workspace:*",
    "@pdf-lib/fontkit": "^1.1.1",
    "@react-pdf/renderer": "^4.3.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@abs/config": "workspace:*",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  }
}
