{
  "name": "abs-data-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "deploy:api": "cd apps/api && wrangler deploy",
    "deploy:db:schema": "wrangler d1 execute abs-data-prod --file=data/abs/schema.sql --remote",
    "deploy:db:migrate": "wrangler d1 execute abs-data-prod --file=data/abs/migrations/001_add_reports.sql --remote && wrangler d1 execute abs-data-prod --file=data/abs/migrations/002_add_auth.sql --remote",
    "deploy": "pnpm run deploy:api"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "wrangler": "^4.80.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd",
      "@react-pdf/pdfkit"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "recharts>react": "19",
        "recharts>react-dom": "19"
      }
    }
  }
}
